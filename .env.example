# ============================================================
#  GIS-projecten — voorbeeld-configuratie
#  Kopieer naar .env (niet in git) en vul je eigen waarden in
# ============================================================

# ── Anthropic API (vereist voor lesa-agent) ─────────────────
# Verkrijg via https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── PostgreSQL / PostGIS (optioneel) ────────────────────────
# Alleen nodig voor Ewaarnemingen / QField-workflow.
# Voor LESA + pastasdash is dit NIET nodig.
PG_HOST=localhost
PG_PORT=5432
PG_DB=ewaarnemingen
PG_SCHEMA=ewaarnemingen

# Pipeline-gebruiker (schrijven)
PG_PIPELINE_USER=ew_pipeline
PG_PIPELINE_PASS=verander_mij

# Read-only collega's
PG_READONLY_USER=ew_collega
PG_READONLY_PASS=verander_mij

# ── geo_stack (optioneel) ───────────────────────────────────
# Pad naar alternatieve data_sources.yaml. Leeg = packaged default.
# GEO_STACK_DATA_SOURCES=

# ── Google Earth Engine (optioneel, alleen voor GEE-skill) ──
# Run 'earthengine authenticate' eenmalig in plaats van dit te zetten.
